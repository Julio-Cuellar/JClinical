<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.jcode.jclinical.infrastructure.ui.ListaExpedientesController"
            styleClass="lista-root">

    <stylesheets>
        <URL value="@../css/lienzo.css" />
    </stylesheets>

    <top>
        <VBox styleClass="lista-header">
            <HBox spacing="14" alignment="CENTER_LEFT">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="🦷  JClinical" styleClass="lista-titulo" />
                    <Label text="Directorio de Expedientes Clínicos — Gestión Estomatológica Digital"
                           styleClass="lista-subtitulo" />
                </VBox>
                <Button fx:id="btnGestorPlantillas" text="📑  Plantillas"
                        styleClass="btn-secundario" />
                <Button fx:id="btnNuevo" text="➕  Nuevo Expediente"
                        styleClass="btn-primario" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="12" style="-fx-padding: 20 28 20 28; -fx-background-color: #EEF8F8;">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Expedientes" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2D5F5F;" />
                <Label text="• Doble clic para abrir  •  Clic derecho para opciones  •  Del para eliminar seleccionado"
                       styleClass="shortcut-hint" />
            </HBox>

            <ListView fx:id="listViewExpedientes" VBox.vgrow="ALWAYS"
                      styleClass="lista-view" style="-fx-pref-height: 420px;" />

            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Label text="Ctrl+N: Nuevo  |  Ctrl+P: Plantillas  |  Enter: Abrir  |  Supr: Eliminar"
                       styleClass="shortcut-hint" />
            </HBox>
        </VBox>
    </center>

</BorderPane>